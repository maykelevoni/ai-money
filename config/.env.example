# ── Traffic network: PropellerAds ──────────────────────────────────────────────
# Self-serve API key from https://ssp.propellerads.com/ → API Settings
PROPELLERADS_API_KEY=

# ── CPA network: MyLead (preferred) ────────────────────────────────────────────
# API key from https://mylead.global/ → Settings → API
MYLEAD_API_KEY=

# ── CPA network: CPALead (fallback) ────────────────────────────────────────────
# Affiliate ID from https://www.cpalead.com/ → Account Info
CPALEAD_AFFILIATE_ID=

# ── LLM (OpenRouter — OpenAI-compatible) ───────────────────────────────────────
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model to use for landing-page + ad-creative generation. Swap freely — any
# OpenRouter model id works (one-line change, no code edit). Options:
#   google/gemini-2.0-flash-001       (DEFAULT: strong copy, cheap, reliable)
#   deepseek/deepseek-chat            (cheapest; good copy, uptime can vary)
#   openai/gpt-4o-mini                (cheap, solid, reliable)
#   anthropic/claude-3.5-haiku        (pricier, excellent copy)
#   openai/gpt-4o / anthropic/claude-3.7-sonnet  (max quality; still pennies at our volume)
LLM_MODEL=google/gemini-2.0-flash-001

# ── Notifications: Telegram ────────────────────────────────────────────────────
# Create a bot via @BotFather → copy the token
TELEGRAM_BOT_TOKEN=
# Your Telegram user/group chat ID (send a message to your bot, then call
# https://api.telegram.org/bot<TOKEN>/getUpdates to find the chat id)
TELEGRAM_CHAT_ID=

# ── VPS / Hosting ──────────────────────────────────────────────────────────────
# Public domain or DuckDNS subdomain pointing at this VPS (no trailing slash)
# Used to build postback URLs and landing-page links registered with the ad network
DOMAIN=https://yourdomain.example.com

# ── Dashboard ──────────────────────────────────────────────────────────────────
# Static token to protect /dashboard — any long random string works
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_TOKEN=

# ── Budget caps (hard limits, never exceeded by engine) ────────────────────────
# GLOBAL_BUDGET: total lifetime ad spend ceiling across all campaigns (USD)
# Engine pauses ALL campaigns + alerts you the moment this is hit
GLOBAL_BUDGET=90.00

# DAILY_CAP: maximum ad spend per calendar day (USD)
# Engine pauses all new spend until the next UTC day when this is hit
DAILY_CAP=10.00

# ── Optimizer thresholds ───────────────────────────────────────────────────────
# SCALE_ROI: minimum ROI % to trigger a winner scale-up (e.g. 0.20 = +20%)
# Campaign must have >= MIN_CONV conversions before scaling is considered
SCALE_ROI=0.20

# KILL_ROI: ROI threshold below which a campaign is killed (e.g. -0.50 = -50%)
# Campaign must have spent >= KILL_SPEND before the kill fires
KILL_ROI=-0.50

# KILL_SPEND: minimum spend (USD) before a campaign is eligible to be killed
# Prevents killing campaigns that haven't had enough data yet
# Rule of thumb: 2–3× the offer payout
KILL_SPEND=3.00

# MIN_ZONE_CLICKS: minimum clicks on a zone before zone-blacklist logic runs
# Avoids blacklisting zones on noise (tiny budget = noisy data)
MIN_ZONE_CLICKS=50

# MIN_CREATIVE_CLICKS: minimum clicks a creative must receive before it can be paused
MIN_CREATIVE_CLICKS=30

# MIN_CONV: minimum conversions a campaign must have before scaling is triggered
MIN_CONV=2
